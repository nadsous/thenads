// Travel planner schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Trip {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  city         String
  country      String
  coverEmoji   String   @default("✈️")
  accentFrom   String   @default("#f97316")
  accentTo     String   @default("#ec4899")
  startDate    DateTime
  endDate      DateTime
  passwordHash String
  notes        String?
  createdAt    DateTime @default(now())

  days   Day[]
  places Place[]
  events TripEvent[]
}

model Day {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  index       Int
  date        DateTime
  label       String
  subtitle    String?
  colorFrom   String
  colorTo     String
  isOff       Boolean  @default(false)
  notes       String?

  places Place[]

  @@unique([tripId, index])
}

model Place {
  id                String  @id @default(cuid())
  tripId            String
  trip              Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayId             String?
  day               Day?    @relation(fields: [dayId], references: [id])
  name              String
  category          String  // monument, museum, cafe, bath, viewpoint, hidden, market
  lat               Float
  lng               Float
  address           String?
  description       String
  humorComment      String
  tip               String?
  openingHours      String? // free-form like "Tous les jours 9h-18h"
  suggestedStart    String? // "10h00"
  suggestedEnd      String? // "12h00"
  durationMinutes   Int?
  segment           String? // morning | afternoon | evening
  orderInDay        Int     @default(0)
  mustReserve       Boolean @default(false)
  isRainyAlt        Boolean @default(false)
  isHidden          Boolean @default(false) // Kolodko hidden statues etc.
  emoji             String  @default("📍")
  priceInfo         String? // ticket prices in HUF/EUR
  crowdLevel        String? // calm | medium | busy | very_busy
  crowdNote         String? // when it's crowded, when it's calm
  bookingUrl        String?
  funFact           String? // "Tu le savais ?" trivia
}

model TripEvent {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name        String
  date        DateTime
  time        String?
  venue       String?
  url         String?
  imageUrl    String?
  category    String?
  createdAt   DateTime @default(now())
}
